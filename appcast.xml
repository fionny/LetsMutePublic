        <item>
            <title>Lets Mute 1.0</title>
            <pubDate>Thu, 22 May 2026 00:00:00 +0000</pubDate>
            <sparkle:version>2</sparkle:version>
            <sparkle:shortVersionString>1.0</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
            <description><![CDATA[
                <h3>Initial release</h3>
                <ul>
                    <li>Mute/unmute Zoom, Microsoft Teams, Webex, and Google Meet with a single hotkey</li>
                    <li>Apple Watch and iPhone companion apps</li>
                    <li>Auto-mute on lock screen and headphone disconnect</li>
                    <li>Calendar integration shows next meeting in menu bar</li>
                </ul>
            ]]></description>
